generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator frontend_types {
  provider = "prisma-client-js"
  output   = "../../front/node_modules/@shared/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id          String         @id @default(cuid())
  album       String?
  artist      String?
  title       String?
  covert      String?
  fileName String

   
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

}
enum DownloadStatus {
  PENDING
  ANALYZING
  AWAITING_CONFIRMATION
  QUEUED_FOR_DOWNLOAD
  DOWNLOADING
  COMPLETED
  FAILED
}

model Download {
  id        String         @id @default(cuid())
  videoId   String         @map("v")
  title     String?
  status    DownloadStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  }