generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum DownloadStatus {
  QUEUED
  DOWNLOADING
  PROCESSING 
  FAILED
}

model Song {
  id          String         @id @default(cuid())
  album       String?
  artist      String?
  title       String?
  fileName String

   
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

}